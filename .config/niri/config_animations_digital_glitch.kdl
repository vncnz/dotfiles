animations {
    window-open {
        duration-ms 350

        curve "linear"

        custom-shader r"
vec4 open_color(vec3 coords_geo, vec3 size_geo) {
    float progress = niri_clamped_progress;
    
    // 1. Easing ultra-veloce: la finestra deve essere quasi tutta presente al 50% del tempo
    float ease = smoothstep(0.0, 1.0, progress);
    
    // 2. Logica del Glitch (attiva solo nella prima metà dell'animazione)
    float glitch_strength = smoothstep(0.5, 0.0, progress); // Svanisce rapidamente
    
    // Creiamo delle fette orizzontali basate sulla coordinata Y
    // Moltiplicando per un numero alto creiamo strisce sottili
    float slice = floor(coords_geo.y * 30.0); 
    
    // Generiamo uno spostamento casuale per ogni fetta
    float slice_hash = fract(sin(slice * 123.456) * 456.789);
    
    // Lo spostamento è laterale (asse X) e dipende dalla forza del glitch
    // Alterniamo destra e sinistra usando (slice_hash - 0.5)
    float x_offset = (slice_hash - 0.5) * 0.1 * glitch_strength;
    
    // 3. Coordinate distorte
    vec2 distorted_coords = coords_geo.xy;
    distorted_coords.x += x_offset;

    // 4. Cromatismo durante il glitch (Red/Cyan shift)
    // Spostiamo i canali colore solo quando le fette si muovono
    float col_shift = 0.02 * glitch_strength * slice_hash;
    
    float r = texture(niri_tex, distorted_coords + vec2(col_shift, 0.0)).r;
    float g = texture(niri_tex, distorted_coords).g;
    float b = texture(niri_tex, distorted_coords - vec2(col_shift, 0.0)).b;
    
    // 5. Apparizione (Alpha + un leggero stretching verticale)
    float within_bounds = step(0.0, distorted_coords.x) * step(distorted_coords.x, 1.0);
    float alpha = ease;

    return vec4(r, g, b, alpha) * within_bounds;
}
        "
    }
    
    window-close {
        duration-ms 200

        curve "linear"

        custom-shader r"
            vec4 close_color(vec3 coords_geo, vec3 size_geo) {
                // Confine to window boundaries
                float within_bounds = step(0.0, coords_geo.x) * step(coords_geo.x, 1.0) *
                                    step(0.0, coords_geo.y) * step(coords_geo.y, 1.0);

                float progress = niri_clamped_progress;
                float inverse_progress = 1.0 - progress;

                // Vertical beam sweep (moves top to bottom as progress increases)
                float beam_pos = progress * 1.2 - 0.1;
                float beam = smoothstep(beam_pos - 0.01, beam_pos, coords_geo.y) *
                            smoothstep(beam_pos + 0.01, beam_pos, coords_geo.y);

                // Glittering noise effect
                float noise = fract(sin(dot(coords_geo.xy, vec2(12.9898, 78.233))) * 43758.5453);
                float sparkle = step(0.95, fract(noise + progress * 5.0));

                // Alpha logic:
                // - Above beam: alpha depends on noise and progress (dissolve effect)
                // - Below beam: alpha is always 1 (solid)
                float alpha;
                if (coords_geo.y > beam_pos) {
                    alpha = 1.0;
                } else {
                    alpha = smoothstep(progress - 0.1, progress, 1.0 - noise);
                }

                // Sample texture
                vec4 color = texture2D(niri_tex, coords_geo.xy);

                // Transporter red-white glow
                vec3 beam_color = vec3(0.9, 0.6, 1.0) * (beam * 2.0 + sparkle);

                // Mix window color with beam glow
                color.rgb = mix(color.rgb, beam_color, (1.0 - alpha) + beam);

                // Combine and clip
                return (color * alpha + vec4(beam_color * beam, 0.0)) * within_bounds;
            }
        "
    }
}