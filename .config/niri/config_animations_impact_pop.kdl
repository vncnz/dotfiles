animations {
    window-open {
        duration-ms 300

        curve "linear"

        custom-shader r"
vec4 open_color(vec3 coords_geo, vec3 size_geo) {
    // 1. Progress con Easing (rende l'inizio veloce e la fine morbida)
    // pow(progress, 0.5) crea una curva che schizza subito in avanti
    float progress = niri_clamped_progress;
    float ease = 1.0 - pow(1.0 - progress, 3.0); 

    // 2. Trasformazione Coordinate (Zoom-out leggero)
    // La finestra parte al 105% e arriva al 100%
    float scale = 1.05 - (0.05 * ease);
    vec2 centered_coords = (coords_geo.xy - 0.5) * scale + 0.5;

    // Controllo bordi (fondamentale per lo zoom)
    float within_bounds = step(0.0, centered_coords.x) * step(centered_coords.x, 1.0) *
                          step(0.0, centered_coords.y) * step(centered_coords.y, 1.0);

    // 3. Effetto Ghosting Cromatismo
    // Spostiamo leggermente i canali R e B in base al progresso residuo
    float shift = (1.0 - ease) * 0.1;
    float r = texture2D(niri_tex, centered_coords + vec2(shift, 0.0)).r;
    float g = texture2D(niri_tex, centered_coords).g;
    float b = texture2D(niri_tex, centered_coords - vec2(shift, 0.0)).b;
    
    vec3 final_rgb = vec3(r, g, b);

    // 4. Fade-in dell'alfa
    float alpha = ease;

    return vec4(final_rgb, alpha) * within_bounds;
}
        "
    }
    
    window-close {
        duration-ms 200

        curve "linear"

        custom-shader r"
            vec4 close_color(vec3 coords_geo, vec3 size_geo) {
                // Confine to window boundaries
                float within_bounds = step(0.0, coords_geo.x) * step(coords_geo.x, 1.0) *
                                    step(0.0, coords_geo.y) * step(coords_geo.y, 1.0);

                float progress = niri_clamped_progress;
                float inverse_progress = 1.0 - progress;

                // Vertical beam sweep (moves top to bottom as progress increases)
                float beam_pos = progress * 1.2 - 0.1;
                float beam = smoothstep(beam_pos - 0.01, beam_pos, coords_geo.y) *
                            smoothstep(beam_pos + 0.01, beam_pos, coords_geo.y);

                // Glittering noise effect
                float noise = fract(sin(dot(coords_geo.xy, vec2(12.9898, 78.233))) * 43758.5453);
                float sparkle = step(0.95, fract(noise + progress * 5.0));

                // Alpha logic:
                // - Above beam: alpha depends on noise and progress (dissolve effect)
                // - Below beam: alpha is always 1 (solid)
                float alpha;
                if (coords_geo.y > beam_pos) {
                    alpha = 1.0;
                } else {
                    alpha = smoothstep(progress - 0.1, progress, 1.0 - noise);
                }

                // Sample texture
                vec4 color = texture2D(niri_tex, coords_geo.xy);

                // Transporter red-white glow
                vec3 beam_color = vec3(0.9, 0.6, 1.0) * (beam * 2.0 + sparkle);

                // Mix window color with beam glow
                color.rgb = mix(color.rgb, beam_color, (1.0 - alpha) + beam);

                // Combine and clip
                return (color * alpha + vec4(beam_color * beam, 0.0)) * within_bounds;
            }
        "
    }
}